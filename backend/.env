# Admin credentials (used for seeding on first run)
ADMIN_USERNAME=vinayak
ADMIN_PASSWORD=echoes@admin2024

# Default app PIN (hashed on first run)
DEFAULT_PIN=1234

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
